# ==============================================================================
# BuildSpace Environment Configuration Template
# Instructions: Copy this file to '.env' and fill in your actual values.
# DO NOT commit your actual '.env' file to version control.
# ==============================================================================

# --- AI & LLM CONFIGURATION ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- AUTHENTICATION ---
JWT_SECRET=your_super_secret_jwt_key_here

# --- PERSISTENCE (PostgreSQL + pgvector) ---
DB_DSN=postgres://admin:secretpassword@postgres:5432/collab_db?sslmode=disable

# --- REAL-TIME MESSAGING (Redis) ---
REDIS_ADDR=redis:6379

# --- ASYNCHRONOUS LOGGING (Kafka) ---
KAFKA_ADDR=kafka:9092

# --- INTERNAL SERVICE ROUTING (gRPC) ---
PYTHON_GRPC_ADDR=llm_python:50051

# --- SERVICE PORTS (External) ---
USER_SERVICE_PORT=8081
COLLAB_SERVICE_PORT=8082
LLM_SERVICE_PORT=8083
FRONTEND_PORT=5173